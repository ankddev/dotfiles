#!/usr/bin/env bash
# hash: {{ include ".chezmoitemplates/packages.yaml" | sha256sum }}

set -eufo pipefail

{{ $pkgData := includeTemplate ".chezmoitemplates/packages.yaml" . | fromYaml -}}

{{ $hasApt := lookPath "apt" }}
{{ $hasDnf := lookPath "dnf" }}
{{ $hasPacman := lookPath "pacman" }}
{{ $hasSnap := lookPath "snap" }}

{{ $aptPackages := list }}
{{ $dnfPackages := list }}
{{ $pacmanPackages := list }}
{{ $aurPackages := list }}
{{ $snaps := list }}
{{ $classicSnaps := list }}
{{ $cargoPackages := list }}
{{ $uvTools := list }}
{{ $npmPackages := list }}
{{ $pipPackages := list }}
{{ $miseTools := list }}
{{ $installScripts := list }}

{{ range $pkgData.packages }}
{{   if and (hasKey . "install") (.install) }}
{{     if and (hasKey . "apt") ($hasApt) }}
{{       $aptPackages = mustAppend $aptPackages .apt }}
{{     else if and (hasKey . "dnf") ($hasDnf) }}
{{       $dnfPackages = mustAppend $dnfPackages .dnf }}
{{     else if and (hasKey . "pacman") ($hasPacman) }}
{{       $pacmanPackages = mustAppend $pacmanPackages .pacman }}
{{     else if and (hasKey . "aur") ($hasPacman)  }}
{{       $aurPackages = mustAppend $aurPackages .aur }}
{{     else if and (hasKey . "snap") ($hasSnap) }}
{{       $snaps = mustAppend $snaps .snap }}
{{     else if and (hasKey . "classic_snap") ($hasSnap) }}
{{       $classicSnaps = mustAppend $classicSnaps .classic_snap }}
{{     else if hasKey . "linux_script" }}
{{       $installScripts = mustAppend $installScripts .linux_script }}
{{     else if hasKey . "cargo" }}
{{       $cargoPackages = mustAppend $cargoPackages .cargo }}
{{     else if hasKey . "uv_tool" }}
{{       $uvTools = mustAppend $uvTools .uv_tool }}
{{     else if hasKey . "npm" }}
{{       $npmPackages = mustAppend $npmPackages .npm }}
{{     else if hasKey . "pip" }}
{{       $pipPackages = mustAppend $pipPackages .pip }}
{{     else if hasKey . "mise" }}
{{       $miseTools = mustAppend $miseTools .mise }}
{{     end }}
{{   end }}
{{ end }}

{{ $sudo := "sudo " -}}
{{ if eq .chezmoi.username "root" -}}
{{   $sudo = "" -}}
{{ end -}}

######
# APT
######

{{ if and ($hasApt) ($aptPackages) }}
echo "Installing packages with APT..."
{{   $sudo }}apt-get update
{{   $sudo }}apt-get install -y {{ $aptPackages | join " " }}
{{ end }}

######
# DNF
######

{{ if and ($hasDnf) ($dnfPackages) }}
echo "Installing packages with DNF..."
{{   $sudo }}dnf -y install {{ $dnfPackages | join " " }}
{{ end }}

#########
# Pacman
#########

{{ if and ($hasPacman) ($pacmanPackages) }}
echo "Installing packages with Pacman..."
{{   $sudo }}pacman -Syu
{{   $sudo }}pacman -S {{ $pacmanPackages | join " " }}
{{ end }}

#######
# Snap
#######

{{ if and ($hasSnap) (or ($snaps) ($classicSnaps)) }}
echo "Installing snaps..."
{{   range $snaps }}
( snap info {{ . }} | grep -q ^installed: ) || {{ $sudo }}snap install {{ . }}
{{   end }}
{{   range $classicSnaps }}
( snap info {{ . }} | grep -q ^installed: ) || {{ $sudo }}snap install --classic {{ . }}
{{   end }}
{{ end }}

########################
# Linux install scripts
########################

{{ range $installScripts }}
echo "Installing package via {{ . }}..."
{{ . }}
{{ end }}

##############
# Update PATH
##############

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.local/share/mise/bin:$PATH"
hash -r
[ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc" || true

#############
# AUR (paru)
#############

{{ if $aurPackages }}
if [ -x "$(command -v paru)" ]; then
    echo "Installing AUR packages..."
    paru -Syu
    paru -S {{ $aurPackages | join " " }}
fi
{{ end }}

#######
# Mise
#######

echo "Installing mise tools..."

{{ if $miseTools }}
mise use -g {{ range $miseTools }}{{ $name := .name }}{{ range .versions }}{{ $name }}@{{ . }} {{ end }}{{ end }}
{{ end }}

#############
# uv Pythons
#############

{{ if and (not .ephemeral) ($pkgData.uv_pythons) }}
echo "Installing Python toolchains via uv..."
uv python install {{ $pkgData.uv_pythons | join " " }}
{{ end }}

###########
# uv tools
###########

{{ if $uvTools }}
echo "Installing uv tools..."

currentUvTools=$(uv tool list)
{{   range $uvTools }}
if [[ ! "$currentUvTools" == *"{{ . }}"* ]]; then
    uv tool install {{ . }}
fi
{{   end }}
{{ end }}

###############
# pip packages
###############

{{ if $pipPackages }}
echo "Installing pip packages..."
uv pip install --system {{ $pipPackages | join " " }}
{{ end }}

###############
# npm packages
###############

{{ if $npmPackages }}
echo "Installing npm packages..."
npm install --global {{ $npmPackages | join " " }}
{{ end }}

#############
# Rust tools
#############

source "$HOME/.cargo/env"
{{ if $cargoPackages }}
if [ -x "$(command -v cargo)" ]; then
    echo "Installing packages with Cargo..."
    cargo binstall --no-confirm {{ $cargoPackages | join " " }}
fi
{{ end }}
