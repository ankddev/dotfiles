  "base_keymap": "VSCode",
  "diff_view_style": "unified",
  "agent": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "use_smartcase_search": true,
  "file_finder": {
    "modal_max_width": "xlarge",
  },
  "show_completion_documentation": true,
  "semantic_tokens": "combined",
  "vim": {
    "highlight_on_yank_duration": 200,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    // TODO: migrate to helix-style no-system-clipboard workflow
    // "use_system_clipboard": "never",
  },
  "minimap": {
    "show": "never",
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "expand_excerpt_lines": 10,
  "status_bar": {
    "line_endings_button": true,
    "active_encoding_button": "enabled",
  },
  "autoscroll_on_clicks": false,
  "vertical_scroll_margin": 6.0,
  "lsp_highlight_debounce": 0,
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
      "delay_ms": 0,
    },
  },
  "preview_tabs": {
    "enabled": false,
  },
  "wsl_connections": [
    {
      "distro_name": "FedoraLinux-43",
      "user": null,
      "projects": [
        {
          "paths": ["/home/ankddev/projects/cpython"],
        },
      ],
    },
  ],
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "hide_mouse": "never",
  "ui_font_family": "Maple Mono NF",
  "ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  "project_panel": {
    "file_icons": true,
    "folder_icons": false,
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "scrollbar": {
      "show": "always",
    },
    "indent_size": 20.0,
    "default_width": 400,
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "active_line_width": 2,
  },
  "tab_bar": {
    "show": false,
  },
  "relative_line_numbers": "enabled",
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "show_whitespaces": "all",
  "use_system_path_prompts": false,
  "debugger": {
    "dock": "bottom",
  },
  "outline_panel": {
    "default_width": 300.0,
    "dock": "left",
  },
  "disable_ai": true,
  "inlay_hints": {
    "enabled": true,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false,
    },
  },
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_weight": 600,
  "bottom_dock_layout": "contained",
  "git_panel": {
    "folder_icons": false,
    "file_icons": false,
    "show_count_badge": true,
    "sort_by_path": false,
    "status_style": "icon",
    "tree_view": true,
    "dock": "left",
  },
  "icon_theme": "Catppuccin Mocha",
  "vim_mode": true,
  "theme": "Catppuccin Mocha",
  "buffer_font_size": 13.0,
  "use_system_prompts": false,
  "title_bar": {
    "show_branch_name": true,
    "show_user_menu": false,
    "show_onboarding_banner": true,
    "show_user_picture": false,
    "show_menus": false,
    "show_project_items": true,
    "show_branch_status_icon": true,
    "show_sign_in": false,
  },
  "autosave": "on_focus_change",
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "all",
  },
  "toolbar": {
    "quick_actions": false,
  },
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "debounce_ms": 0,
    },
    "inline": {
      "update_debounce_ms": 0,
      "enabled": true,
    },
  },
  "wrap_guides": [80, 120],
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "show_count_badge": true,
    "font_size": 15,
    "font_family": "Maple Mono NF",
    "shell": {
      "program": "nu",
    },
    "font_features": {
      "calt": true,
      "liga": true,
      "cv41": true,
      "cv42": true,
      "cv66": true,
      "ss03": true,
      "ss08": true,
      "ss09": true,
      "ss10": true,
      "ss11": true,
    },
  },
  "buffer_font_features": {
    "liga": true,
    "calt": true,
    "cv41": true,
    "cv42": true,
    "cv66": true,
    "ss03": true,
    "ss08": true,
    "ss09": true,
    "ss10": true,
    "ss11": true,
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },
  "theme_overrides": {
    "Catppuccin Mocha": {
      "border.variant": "#313244",
      "status_bar.background": "#1e1e2e",
      "title_bar.background": "#1e1e2e",
      "title_bar.inactive_background": "#171725",
      "panel.background": "#1e1e2e",
      "background": "#1e1e2e",
      "scrollbar.track.background": "#1e1e2e",
      "tab_bar.background": "#1e1e2e",
      "tab.inactive_background": "#1e1e2e",
      "syntax": {
        "boolean": {
          "font_style": "italic",
        },
        "number.float": {
          "font_style": "italic",
        },
        "number": {
          "font_style": "italic",
        },
        "keyword.return": {
          "font_style": "italic",
        },
        "keyword.coroutine": {
          "font_style": "italic",
        },
        "keyword.export": {
          "font_style": "italic",
        },
      },
    },
  },
  "command_aliases": {
    "ext": "zed::Extensions",
  },
}
