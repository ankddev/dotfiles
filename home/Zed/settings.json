  "buffer_font_features": {
    "liga": true,
    "calt": true,
    "cv41": true,
    "cv42": true,
    "cv66": true,
    "ss03": true,
    "ss08": true,
    "ss09": true,
    "ss10": true,
    "ss11": true,
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },
