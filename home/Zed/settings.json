  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "hide_mouse": "never",
  "ui_font_family": "Maple Mono NF",
  "project_panel": {
    "indent_guides": {
      "show": "never",
    },
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "sort_mode": "directories_first",
