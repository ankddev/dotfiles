# vim: ft=gitignore:
# Common ignores
scripts
Zed

# Windows-specific
{{ if ne .chezmoi.os "windows" }}
AppData/
.wslconfig
.chezmoiscripts/windows/*
{{ end }}

# Unix-specific
{{ if eq .chezmoi.os "windows" }}
.config/helix
{{ end }}

# Linux and Android-specific
{{ if and (ne .chezmoi.os "linux") (ne .chezmoi.os "android") }}
.config/nushell/
.chezmoiscripts/linux/*
{{ end }}

# macOS-specific
{{ if ne .chezmoi.os "darwin" }}
Library/
.chezmoiscripts/darwin/*
{{ end }}

# GUI-specific
{{ if .headless }}
.atom/
.config/zed/
AppData/Roaming/Zed/
{{ end }}
